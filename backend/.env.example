# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL - Railway.app)
DATABASE_URL="postgresql://user:password@localhost:5432/campusbite"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# Hubtel MoMo (Ghana)
HUBTEL_CLIENT_ID=your_hubtel_client_id
HUBTEL_CLIENT_SECRET=your_hubtel_client_secret
HUBTEL_MERCHANT_ID=your_hubtel_merchant_id
HUBTEL_CALLBACK_URL=https://your-domain.com/api/payments/callback

# Arkesel SMS (Ghana)
ARKESEL_API_KEY=your_arkesel_api_key
ARKESEL_SENDER_ID=CampusBite

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# App
FRONTEND_URL=http://localhost:3000
APP_NAME=CampusBite
